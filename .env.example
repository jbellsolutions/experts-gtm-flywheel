# ─────────────────────────────────────────────
# AgentStack Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── LLM APIs ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Airtop ────────────────────────────────────
AIRTOP_API_KEY=your-airtop-api-key
AIRTOP_PROFILE_ID=your-linkedin-session-profile-id

# ── Slack ─────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_SIGNING_SECRET=your-signing-secret

# ── CRM ───────────────────────────────────────
HUBSPOT_API_KEY=your-hubspot-private-app-token
AIRTABLE_API_KEY=your-airtable-personal-access-token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ── Email Sending ─────────────────────────────
INSTANTLY_API_KEY=your-instantly-api-key
SMARTLEAD_API_KEY=your-smartlead-api-key

# ── GitHub ────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── LinkedIn (Computer Use agents) ────────────
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# ── ClickUp ───────────────────────────────────
CLICKUP_API_KEY=your-clickup-api-key

# ── External Integrations ─────────────────────
STRIPE_SECRET_KEY=sk_live_...
QUICKBOOKS_CLIENT_ID=your-qb-client-id
QUICKBOOKS_CLIENT_SECRET=your-qb-client-secret

# ── Content Flywheel ──────────────────────────
TYPEFULLY_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
YOUTUBE_CHANNEL_HANDLE=
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_LINKEDIN_ACCOUNT_ID=
SUBSTACK_PUBLICATION_URL=
CONVERTKIT_API_SECRET=
RAILWAY_TOKEN=
SLACK_OPERATOR_USER_ID=
SUPABASE_ACCESS_TOKEN=
REDIS_URL=
BROWSER_PROFILES_DIR=
BROWSER_USE_API_KEY=               # Browser Use Cloud (Substack/Medium publish)

# ── Lead-gen pipeline (see LEADGEN.md) ────────
# Airtable CRM keys are in the CRM section above (AIRTABLE_API_KEY / AIRTABLE_BASE_ID).
APIFY_TOKEN=                       # primary post-engager scrape (keep funded for full coverage)
SCRAPECREATORS_API_KEY=            # fallback engager scrape
BRIGHTDATA_API_TOKEN=              # company enrichment
FULLENRICH_API_KEY=                # verified work email (emails only)
FIRECRAWL_API_KEY=                 # company homepage scrape/search
SMARTLEAD_CAMPAIGN_ID=             # default campaign for "Push to campaign" (e.g. 3520103)

# ── Newsletter + publishing tuning ────────────
NEWSLETTER_AUTOSEND=false          # false => create a Kit DRAFT for review; true => auto-send to the list
NEWSLETTER_BRAND_NAME=[Your Brand]   # email header wordmark
NEWSLETTER_CTA_TEXT=Work with us
NEWSLETTER_CTA_URL=https://usingaitoscale.com
NEWSLETTER_COVER_DEADLINE_MIN=90   # publish a newsletter cover-less only after this long past its slot
PUBLISH_POSTS_PER_WINDOW=2         # throttle: feed posts published per cron window (spreads backlog)
PUBLISH_LONGFORM_PER_WINDOW=1      # throttle: long-form (article/newsletter) per window

# ── App Config ────────────────────────────────
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO
COST_ALERT_THRESHOLD_USD=50    # Alert if daily costs exceed this
ICP_SCORE_THRESHOLD=70         # Minimum score to qualify a lead
